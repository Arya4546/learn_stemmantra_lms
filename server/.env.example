# ──────────────────────────────────────────────
# Stem Mantra LMS — Environment Configuration
# ──────────────────────────────────────────────

# Runtime environment: development | production | test
NODE_ENV=development

# Server port
PORT=3000

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/stemmantra_lms

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_char_random_hex_string
JWT_REFRESH_SECRET=replace_with_different_64_char_random_hex_string

# JWT expiry durations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Default admin account — seeded on first startup
ADMIN_EMAIL=admin@stemmantra.com
ADMIN_PASSWORD=ChangeThisPassword!2024
ADMIN_FULL_NAME=Stem Mantra Admin

# CORS — allowed frontend origin (comma-separated for multiple)
CORS_ORIGIN=http://localhost:5173

# Content access token TTL in seconds (default: 5 minutes)
CONTENT_TOKEN_EXPIRY_SECONDS=300

# Upload directory (relative to project root)
UPLOAD_DIR=./uploads

# Maximum file upload size in bytes (default: 500MB)
MAX_FILE_SIZE=524288000

# Logging level: error | warn | info | http | debug
LOG_LEVEL=info
